{
  "name": "prompt-optimizer-vscode-lite",
  "displayName": "Prompt Optimizer Lite",
  "description": "Use current VS Code chat model to optimize prompts, with local Python fallback when model invocation fails.",
  "version": "1.0.0",
  "publisher": "lab-overflow",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lab-Overflow/prompt-optimizer-lite"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Machine Learning",
    "Chat",
    "Other"
  ],
  "keywords": [
    "prompt",
    "optimizer",
    "chat",
    "copilot",
    "codex",
    "claude"
  ],
  "activationEvents": [
    "onChatParticipant:prompt-optimizer-lite.promptOptimizer",
    "onCommand:promptOptimizerLite.optimizeSelection"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptOptimizerLite.optimizeSelection",
        "title": "Prompt Optimizer Lite: Optimize Prompt"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "promptOptimizerLite.optimizeSelection",
          "group": "1_modification",
          "when": "editorHasSelection"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "prompt-optimizer-lite.promptOptimizer",
        "name": "promptopt",
        "fullName": "Prompt Optimizer Lite",
        "description": "Optimize rough prompts into senior prompt-engineer quality. Type @promptopt followed by your rough idea to get an execution-ready prompt.",
        "isSticky": true
      }
    ],
    "configuration": {
      "title": "Prompt Optimizer Lite",
      "properties": {
        "promptOptimizerLite.replaceSelection": {
          "type": "boolean",
          "default": false,
          "description": "When true, replace selected text directly when a selection exists. Otherwise show action picker."
        },
        "promptOptimizerLite.fallbackPythonCommand": {
          "type": "string",
          "default": "",
          "description": "Optional python command override. Example: /usr/bin/python3"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepackage": "cp README.md README.github.md && cp README.marketplace.md README.md",
    "package": "vsce package",
    "postpackage": "cp README.github.md README.md && rm README.github.md"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.105.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
